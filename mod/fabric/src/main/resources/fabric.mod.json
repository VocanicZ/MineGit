{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "MineGit",
  "description": "Git-backed version control for Minecraft worlds — single-player capable (integrated server).",
  "authors": ["RainBowCreation", "VocanicZ", "NathanielSong"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["net.rainbowcreation.vocanicz.minegit.mod.MineGitFabric"],
    "client": ["net.rainbowcreation.vocanicz.minegit.mod.MineGitFabricClient"],
    "fabric-gametest": ["net.rainbowcreation.vocanicz.minegit.mod.MineGitFabricGameTest"]
  },
  "mixins": ["minegit.mixins.json"],
  "depends": {
    "fabricloader": ">=0.16",
    "minecraft": ">=1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "architectury": "*"
  }
}
